{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3AttachmentsLeastPrivilege",
      "Effect": "Allow",
      "Action": ["s3:PutObject", "s3:GetObject", "s3:ListBucket"],
      "Resource": [
        "arn:aws:s3:::taskflow-attachments-production",
        "arn:aws:s3:::taskflow-attachments-production/*"
      ]
    },
    {
      "Sid": "ECRReadOnly",
      "Effect": "Allow",
      "Action": [
        "ecr:GetAuthorizationToken",
        "ecr:BatchGetImage",
        "ecr:GetDownloadUrlForLayer"
      ],
      "Resource": "*"
    }
  ]
}