{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "API Health",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "taskflow_api_healthy{namespace=\"$namespace\"}",
          "legendFormat": "healthy"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "Total Tasks",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "taskflow_tasks_total{namespace=\"$namespace\"}",
          "legendFormat": "tasks"
        }
      ]
    },
    {
      "title": "Active Users",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "taskflow_active_users{namespace=\"$namespace\"}",
          "legendFormat": "users"
        }
      ]
    },
    {
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "rate(taskflow_http_requests_total{namespace=\"$namespace\", service=\"$service\"}[5m])",
          "legendFormat": "{{method}} {{status}}"
        }
      ]
    },
    {
      "title": "p95 Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(taskflow_http_request_duration_seconds_bucket{namespace=\"$namespace\"}[5m]))",
          "legendFormat": "p95"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["taskflow", "platform-engineering"],
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "query": "label_values(taskflow_api_healthy, namespace)",
        "current": { "text": "taskflow", "value": "taskflow" },
        "label": "Environment",
        "refresh": 2
      },
      {
        "name": "service",
        "type": "custom",
        "query": "taskflow-api,taskflow-ui,taskflow-exporter",
        "current": { "text": "taskflow-api", "value": "taskflow-api" },
        "label": "Service"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "TaskFlow Platform Overview",
  "uid": "taskflow-overview",
  "version": 1
}